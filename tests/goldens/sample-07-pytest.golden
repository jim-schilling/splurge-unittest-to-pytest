from unittest.mock import Mock, patch, MagicMock
import threading
import time
import queue
from typing import List, Dict, Any, Generator

import pytest



@pytest.fixture
def test_items() -> List[Dict[str, Any]]:
    """Test data items for processing."""
    return [
        {"id": 1, "data": "item1"},
        {"id": 2, "data": "item2"},
        {"id": 3, "data": "item3"}
    ]

@pytest.fixture
def input_queue(test_items: List[Dict[str, Any]]) -> queue.Queue:
    """Input queue with test data."""
    q = queue.Queue()
    for item in test_items:
        q.put(item)
    return q

@pytest.fixture
def output_queue() -> queue.Queue:
    """Output queue for processed items."""
    return queue.Queue()

@pytest.fixture
def error_queue() -> queue.Queue:
    """Error queue for failed items."""
    return queue.Queue()

@pytest.fixture
def mock_processor() -> Mock:
    """Mock processor service."""
    return Mock()

@pytest.fixture
def mock_validator() -> Mock:
    """Mock validator service."""
    return Mock()

@pytest.fixture
def mock_database() -> Mock:
    """Mock database connection."""
    return Mock()

@pytest.fixture
def worker_threads() -> List[threading.Thread]:
    """List to track worker threads."""
    return []

@pytest.fixture
def stop_event() -> threading.Event:
    """Event to signal threads to stop."""
    return threading.Event()

@pytest.fixture
def concurrent_processor_setup(
    input_queue: queue.Queue,
    output_queue: queue.Queue,
    error_queue: queue.Queue,
    worker_threads: List[threading.Thread],
    stop_event: threading.Event
) -> Generator[Dict[str, Any], None, None]:
    """Set up concurrent processor with cleanup."""
    def clear_queue(q: queue.Queue) -> None:
        """Helper to clear a queue."""
        try:
            while True:
                q.get_nowait()
        except queue.Empty:
            pass
    
    try:
        yield {
            "input_queue": input_queue,
            "output_queue": output_queue,
            "error_queue": error_queue,
            "worker_threads": worker_threads,
            "stop_event": stop_event
        }
    finally:
        # Signal all threads to stop
        stop_event.set()
        
        # Wait for all threads to finish
        for thread in worker_threads:
            if thread.is_alive():
                thread.join(timeout=1.0)
                
        # Clear all queues
        clear_queue(input_queue)
        clear_queue(output_queue)
        clear_queue(error_queue)

@patch('time.sleep')
def test_single_item_processing(
    mock_sleep,
    test_items: List[Dict[str, Any]],
    mock_processor: Mock,
    mock_validator: Mock
) -> None:
    """Test single item processing functionality."""
    mock_sleep.return_value = None  # Speed up test
    mock_processor.process.return_value = {"processed": True}
    mock_validator.validate.return_value = True
    
    # Test single item processing
    item = test_items[0]
    
    # Simulate processing
    validated = mock_validator.validate(item)
    assert validated is True
    
    result = mock_processor.process(item)
    assert "processed" in result
    assert result["processed"] is True

def test_queue_operations(
    input_queue: queue.Queue,
    output_queue: queue.Queue
) -> None:
    """Test queue operations functionality."""
    # Test queue has items
    assert not input_queue.empty()
    assert input_queue.qsize() == 3
    
    # Test getting items
    item = input_queue.get()
    assert item["id"] == 1
    assert input_queue.qsize() == 2
    
    # Test putting items in output queue
    processed_item = {"id": item["id"], "status": "completed"}
    output_queue.put(processed_item)
    assert output_queue.qsize() == 1

@patch('threading.Thread')
def test_worker_thread_creation(mock_thread_class, worker_threads: List[threading.Thread]) -> None:
    """Test worker thread creation."""
    mock_thread = Mock()
    mock_thread_class.return_value = mock_thread
    
    # Simulate thread creation
    thread = mock_thread_class(target=lambda: None, daemon=True)
    worker_threads.append(thread)
    
    assert len(worker_threads) == 1
    mock_thread_class.assert_called_once()
