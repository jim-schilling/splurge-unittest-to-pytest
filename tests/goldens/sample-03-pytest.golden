import requests
from unittest.mock import patch, Mock
from typing import Dict, Any, Generator

import pytest



@pytest.fixture(scope="session")
def api_config() -> Dict[str, str]:
    """API configuration shared across all tests."""
    return {
        "base_url": "https://api.example.com",
        "api_key": "test_api_key"
    }

@pytest.fixture(scope="session")
def api_headers(api_config: Dict[str, str]) -> Dict[str, str]:
    """API headers for requests."""
    return {
        "Authorization": f"Bearer {api_config['api_key']}",
        "Content-Type": "application/json"
    }

@pytest.fixture(scope="session")
def api_session(api_headers: Dict[str, str]) -> Generator[requests.Session, None, None]:
    """Requests session with configured headers."""
    session = requests.Session()
    session.headers.update(api_headers)
    try:
        yield session
    finally:
        session.close()

@pytest.fixture
def endpoint() -> str:
    """API endpoint for user operations."""
    return "/users"

@pytest.fixture
def test_user_id() -> int:
    """Test user ID."""
    return 123

@pytest.fixture
def expected_response(test_user_id: int) -> Dict[str, Any]:
    """Expected API response."""
    return {
        "id": test_user_id,
        "name": "Test User",
        "email": "test@example.com"
    }

@patch('requests.Session.get')
def test_get_user(
    mock_get,
    api_session: requests.Session,
    api_config: Dict[str, str],
    endpoint: str,
    test_user_id: int,
    expected_response: Dict[str, Any]
) -> None:
    """Test getting user from API."""
    mock_response = Mock()
    mock_response.json.return_value = expected_response
    mock_response.status_code = 200
    mock_get.return_value = mock_response
    
    url = f"{api_config['base_url']}{endpoint}/{test_user_id}"
    response = api_session.get(url)
    
    assert response.status_code == 200
    assert response.json() == expected_response
    mock_get.assert_called_once_with(url)

@patch('requests.Session.post')
def test_create_user(
    mock_post,
    api_session: requests.Session,
    api_config: Dict[str, str],
    endpoint: str
) -> None:
    """Test creating user via API."""
    user_data = {"name": "New User", "email": "new@example.com"}
    mock_response = Mock()
    mock_response.json.return_value = {**user_data, "id": 456}
    mock_response.status_code = 201
    mock_post.return_value = mock_response
    
    url = f"{api_config['base_url']}{endpoint}"
    response = api_session.post(url, json=user_data)
    
    assert response.status_code == 201
    assert "id" in response.json()
    mock_post.assert_called_once_with(url, json=user_data)
