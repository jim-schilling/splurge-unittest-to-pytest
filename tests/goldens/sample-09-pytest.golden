from unittest.mock import Mock, patch, MagicMock
import requests
import time
import os
from contextlib import contextmanager
from typing import Dict, Any, List, Generator

import pytest



@pytest.fixture(scope="session")
def api_config() -> Dict[str, Any]:
    """API configuration from environment variables."""
    return {
        'base_url': os.getenv('API_BASE_URL', 'https://api.example.com'),
        'token': os.getenv('API_TOKEN', 'test_token'),
        'timeout': int(os.getenv('API_TIMEOUT', '30'))
    }

@pytest.fixture(scope="session") 
def service_registry(api_config: Dict[str, Any]) -> Dict[str, str]:
    """Service registry with API endpoints."""
    base_url = api_config['base_url']
    return {
        'auth_service': f'{base_url}/auth',
        'user_service': f'{base_url}/users',
        'data_service': f'{base_url}/data'
    }

@pytest.fixture
def api_session(api_config: Dict[str, Any]) -> Generator[requests.Session, None, None]:
    """HTTP session with API configuration."""
    session = requests.Session()
    session.headers.update({
        'Authorization': f'Bearer {api_config["token"]}',
        'Content-Type': 'application/json'
    })
    try:
        yield session
    finally:
        session.close()

@pytest.fixture
def mock_auth_response() -> Dict[str, Any]:
    """Mock authentication response data."""
    return {
        'token': 'mock_auth_token',
        'expires_in': 3600,
        'user_id': 'test_user_123'
    }

@pytest.fixture
def mock_user_data() -> Dict[str, Any]:
    """Mock user data."""
    return {
        'id': 'test_user_123',
        'username': 'testuser', 
        'email': 'test@example.com',
        'created_at': '2024-01-01T00:00:00Z'
    }

@pytest.fixture
def performance_tracker() -> List[float]:
    """Performance data tracker."""
    return []

@contextmanager
def measure_time(performance_data: List[float]):
    """Context manager to measure execution time."""
    start_time = time.time()
    try:
        yield
    finally:
        end_time = time.time()
        performance_data.append(end_time - start_time)

def mock_successful_response(data: Dict[str, Any], status_code: int = 200) -> Mock:
    """Helper to create mock successful response."""
    mock_response = Mock()
    mock_response.json.return_value = data
    mock_response.status_code = status_code
    mock_response.raise_for_status.return_value = None
    return mock_response

def mock_error_response(status_code: int, error_message: str) -> Mock:
    """Helper to create mock error response."""
    mock_response = Mock()
    mock_response.status_code = status_code
    mock_response.json.return_value = {'error': error_message}
    mock_response.raise_for_status.side_effect = requests.HTTPError(error_message)
    return mock_response

@patch('requests.Session.post')
def test_authentication_flow(
    mock_post,
    api_session: requests.Session,
    service_registry: Dict[str, str],
    mock_auth_response: Dict[str, Any],
    performance_tracker: List[float]
) -> None:
    """Test authentication flow with performance tracking."""
    mock_post.return_value = mock_successful_response(mock_auth_response)
    
    with measure_time(performance_tracker):
        # Simulate authentication
        auth_url = service_registry['auth_service']
        response = api_session.post(auth_url, json={
            'username': 'testuser',
            'password': 'testpass'
        })
        
    assert response.status_code == 200
    auth_data = response.json()
    assert 'token' in auth_data
    assert auth_data['user_id'] == 'test_user_123'
    
    # Verify the request was made correctly
    mock_post.assert_called_once()
    call_args = mock_post.call_args
    assert call_args[0][0] == auth_url

@patch('requests.Session.get')
@patch('requests.Session.post')
def test_user_data_retrieval_after_auth(
    mock_post,
    mock_get,
    api_session: requests.Session,
    service_registry: Dict[str, str],
    mock_auth_response: Dict[str, Any],
    mock_user_data: Dict[str, Any]
) -> None:
    """Test user data retrieval after authentication."""
    # Setup auth mock
    mock_post.return_value = mock_successful_response(mock_auth_response)
    
    # Setup user data mock
    mock_get.return_value = mock_successful_response(mock_user_data)
    
    # First authenticate
    auth_response = api_session.post(
        service_registry['auth_service'],
        json={'username': 'testuser', 'password': 'testpass'}
    )
    assert auth_response.status_code == 200
    
    # Then get user data
    user_id = auth_response.json()['user_id']
    user_response = api_session.get(
        f"{service_registry['user_service']}/{user_id}"
    )
    
    assert user_response.status_code == 200
    user_data = user_response.json()
    assert user_data['id'] == user_id
    assert user_data['username'] == 'testuser'

@pytest.mark.parametrize("status_code,error_message", [
    (404, 'User not found'),
    (500, 'Internal server error'),
    (403, 'Insufficient permissions')
])
@patch('requests.Session.get')
def test_service_error_handling(
    mock_get,
    status_code: int,
    error_message: str,
    api_session: requests.Session,
    service_registry: Dict[str, str]
) -> None:
    """Test service error handling for different HTTP errors."""
    mock_get.return_value = mock_error_response(status_code, error_message)
    
    response = api_session.get(f"{service_registry['user_service']}/invalid")
    
    assert response.status_code == status_code
    with pytest.raises(requests.HTTPError):
        response.raise_for_status()

@patch('requests.Session.get')
def test_timeout_handling(
    mock_get,
    api_session: requests.Session,
    service_registry: Dict[str, str],
    api_config: Dict[str, Any]
) -> None:
    """Test timeout handling."""
    mock_get.side_effect = requests.Timeout("Request timed out")
    
    with pytest.raises(requests.Timeout):
        api_session.get(service_registry['data_service'], timeout=api_config['timeout'])

@patch('time.sleep')  # Speed up retry logic in tests
@patch('requests.Session.get')
def test_retry_mechanism(
    mock_get,
    mock_sleep,
    api_session: requests.Session,
    service_registry: Dict[str, str]
) -> None:
    """Test retry mechanism with exponential backoff."""
    mock_sleep.return_value = None
    
    # First two calls fail, third succeeds
    mock_get.side_effect = [
        requests.ConnectionError("Connection failed"),
        requests.ConnectionError("Connection failed"),
        mock_successful_response({'status': 'success'})
    ]
    
    # Simulate retry logic (would be in actual application code)
    max_retries = 3
    for attempt in range(max_retries):
        try:
            response = api_session.get(service_registry['data_service'])
            break
        except requests.ConnectionError:
            if attempt == max_retries - 1:
                raise
            time.sleep(2 ** attempt)  # Exponential backoff
            
    assert response.status_code == 200
    assert mock_get.call_count == 3
