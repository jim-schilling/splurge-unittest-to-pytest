import tempfile
import shutil
from pathlib import Path
import pytest


@pytest.fixture
def temp_dir():
    _temp_dir_value = tempfile.mkdtemp()
    yield _temp_dir_value
    shutil.rmtree(_temp_dir_value, ignore_errors=True)


@pytest.fixture
def config_dir(temp_dir):
    return Path(temp_dir) / "conf"
